DATABASE_URL=postgresql://postgres:postgres@localhost:5433/agentx?schema=public
REDIS_URL=redis://localhost:6379
PORT=3000

OPENROUTER_API_KEY=
OPENAI_API_KEY=
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev

CHAT_MODEL=openai/gpt-4o-mini
EXTRACT_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# RAG retrieval
RAG_TOP_K=5
RAG_MIN_SCORE=0.2

SAFETY_MESSAGE=I can't help with that. Let's keep things on-topic.

# Inspector / debug traces (dev only — never enable in prod)
DEBUG_INSPECTOR=true
DEBUG_DIRECTOR_TRACE=true
DEBUG_RAG_TRACE=true
DEBUG_LLM_TRACE=true
DEBUG_PROMPT_CAPTURE=true
DEBUG_PHASE_TIMING=true
DEBUG_PIPELINE_TRACE=true
DEBUG_TOOL_TRACE=true
ALLOW_INSPECTOR_IN_PROD=false
